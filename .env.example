# Environment variables for {{ project_name }}
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# GitHub token for CI/CD (optional - only needed for Coveralls)
# GITHUB_TOKEN=

# Coveralls repo token (optional - only needed for coverage tracking)
# COVERALLS_REPO_TOKEN=

# TODO: Add your project-specific environment variables below.
# Example:
# API_KEY=your_api_key_here
# DEBUG=false
# LOG_LEVEL=INFO
